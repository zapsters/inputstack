{
  "name": "inputstack",
  "version": "1.3.0",
  "description": "A frantic, real-time multiplayer game where players must work together to manage an ever-growing stack of tasks.",
  "main": "index.js",
  "scripts": {
    "liveserver": "live-server dist --port=8000",
    "emulators:start": "firebase emulators:start",
    "emulators:stop": "npx kill-port 4000 8080 8085 9000",
    "sass": "sass src/sass/styles.scss dist/css/styles.css -w",
    "build": "webpack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zapsters/inputstack.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/zapsters/inputstack/issues"
  },
  "homepage": "https://github.com/zapsters/inputstack#readme",
  "devDependencies": {
    "sass": "^1.85.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "firebase": "^11.3.1",
    "jquery": "^3.7.1",
    "pixelarticons": "^1.8.1",
    "sanitize-html": "^2.14.0"
  }
}
